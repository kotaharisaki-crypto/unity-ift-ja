  m_Name: NarrativeParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "\u30ED\u30DC\u30C3\u30C8\u306E\u69CB\u6210\u304C\u5B8C\u4E86\u3057\u3001\u30E6\u30FC\u30B6\u30FC\u30A4\u30F3\u30BF\u30FC\u30D5\u30A7\u30FC\u30B9\u306B\u63A5\u7D9A\u3055\u308C\u305F\u306E\u3067\u3001Play
      \u30E2\u30FC\u30C9\u3067\u30C6\u30B9\u30C8\u3057\u3066\u307F\u307E\u3057\u3087\u3046\u3002\u30B7\u30FC\u30F3\u3092\u5B9F\u884C\u3059\u308B\u3068\u3001\u30ED\u30DC\u30C3\u30C8\u306F\u81EA\u52D5\u7684\u306B\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9
      UI \u306B\u767B\u9332\u3055\u308C\u3001\u305D\u306E\u30C7\u30FC\u30BF\u3092\u8868\u793A\u3057\u305F\u308A\u30AB\u30E1\u30E9\u3067\u8FFD\u8DE1\u3057\u305F\u308A\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002\n\n<b>\u6CE8:</b>
      \u30A2\u30D7\u30EA\u30B1\u30FC\u30B7\u30E7\u30F3\u30E1\u30CB\u30E5\u30FC\u3092\u898B\u3084\u3059\u304F\u3059\u308B\u305F\u3081\u306B\u3001Game
      \u30A6\u30A3\u30F3\u30C9\u30A6\u3092\u6700\u5927\u5316\u3059\u308B\u3053\u3068\u3092\u304A\u52E7\u3081\u3057\u307E\u3059\u3002\n\n"
--- !u!114 &3797890493361399074
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9</b> \u3067
      <b>Manual</b> \u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u307E\u3059\u3002
      <b>WASD</b> \u30AD\u30FC\u3092\u4F7F\u7528\u3057\u3066\u3001\u30B7\u30FC\u30F3\u5185\u3067\u30ED\u30DC\u30C3\u30C8\u3092\u624B\u52D5\u3067\u52D5\u304B\u3059\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002\n\n2.
      <b>Speed</b> \u30D7\u30ED\u30D1\u30C6\u30A3\u3092\u898B\u3064\u3051\u3066\u3001\u305D\u306E\u5024\u3092
      <b>10</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002 <b>WASD</b> \u30AD\u30FC\u3092\u3082\u3046\u4E00\u5EA6\u4F7F\u7528\u3057\u3066\u3001\u30ED\u30DC\u30C3\u30C8\u304C\u901F\u304F\u52D5\u304F\u3088\u3046\u306B\u306A\u3063\u305F\u3053\u3068\u3092\u78BA\u8A8D\u3057\u307E\u3059\u3002\n\n3.
      UI \u306E <b>Auto</b> \u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u307E\u3059\u3002\u5236\u5FA1\u30B9\u30E9\u30A4\u30C0\u30FC\u304C\u30ED\u30C3\u30AF\u3055\u308C\u3001\u30ED\u30DC\u30C3\u30C8\u304C\u624B\u52D5\u3067\u5236\u5FA1\u3055\u308C\u306A\u304F\u306A\u3063\u305F\u3053\u3068\u3092\u793A\u3057\u307E\u3059\u3002\u30ED\u30DC\u30C3\u30C8\u306F\u30D1\u30B9\u30D5\u30A1\u30A4\u30F3\u30C7\u30A3\u30F3\u30B0\u3092\u4F7F\u7528\u3057\u3066\u3001\u5009\u5EAB\u306E\u30A6\u30A7\u30A4\u30DD\u30A4\u30F3\u30C8\u9593\u3092\u81EA\u52D5\u7684\u306B\u79FB\u52D5\u3057\u59CB\u3081\u307E\u3059\u3002\n\n4.
      <b>Play \u30E2\u30FC\u30C9</b> \u3092\u505C\u6B62\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
