--- !u!114 &-4592439337752858390
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Assets > 3DModels</b> \u3067\u3001\u65B0\u3057\u304F\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F
      <b>Moto \u30D7\u30EC\u30CF\u30D6</b>\u3092\u518D\u5EA6\u898B\u3064\u3051\u3066\u3001<b>Hierarchy</b>
      \u306B\u30C9\u30E9\u30C3\u30B0\u3057\u307E\u3059\u3002\n\n2. <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067
      <b>Transform</b> \u3092\u3082\u3046\u4E00\u5EA6\u30EA\u30BB\u30C3\u30C8\u3057\u3001\u30D7\u30EC\u30CF\u30D6\u3092\u30B7\u30FC\u30F3\u306E\u4E2D\u5FC3\u306B\u914D\u7F6E\u3057\u307E\u3059\u3002\n\n3.
      <b>Hierarchy \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Moto</b> GameObject
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4. <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067
      <b>Add Component</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5. <b>Robot</b>
      \u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u3092\u691C\u7D22\u3057\u3066\u8FFD\u52A0\u3057\u307E\u3059\u3002\n\n6.
      Inspector \u30A6\u30A3\u30F3\u30C9\u30A6\u306E\u4E0A\u90E8\u306B\u3042\u308B
      <b>\u5357\u4EAC\u9320\u30A2\u30A4\u30B3\u30F3</b> \u3092\u9078\u629E\u3057\u3066\u3001\u30ED\u30DC\u30C3\u30C8\u60C5\u5831\u3092\u8868\u793A\u3057\u305F\u307E\u307E\u306B\u3057\u307E\u3059\u3002\n\n7.
      <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets > Warehouse >
      RobotData</b> \u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n8. \u30D5\u30A9\u30EB\u30C0\u5185\u3092\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3001<b>Create
      > Industry Template > Robot Data</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\u30ED\u30DC\u30C3\u30C8\u56FA\u6709\u306E\u60C5\u5831\u3092\u4FDD\u5B58\u3059\u308B\u65B0\u3057\u3044
      ScriptableObject \u304C\u4F5C\u6210\u3055\u308C\u307E\u3059\u3002\n\n9. \u65B0\u3057\u304F\u4F5C\u6210\u3057\u305F
      <b>Robot Data</b> \u30A2\u30BB\u30C3\u30C8\u3092\u3001<b>Moto</b> GameObject
      \u306E <b>Robot</b> \u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u306E <b>Data</b>
      \u30D5\u30A3\u30FC\u30EB\u30C9\u306B\u30C9\u30E9\u30C3\u30B0\u3057\u307E\u3059\u3002\u65B0\u3057\u3044\u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u304C\u81EA\u52D5\u7684\u306B\u8FFD\u52A0\u3055\u308C\u308B\u306E\u304C\u308F\u304B\u308A\u307E\u3059\u3002\u3053\u308C\u3089\u306F\u3001\u30ED\u30DC\u30C3\u30C8\u3092\u30B7\u30FC\u30F3\u306B\u30EA\u30F3\u30AF\u3059\u308B\u305F\u3081\u306B\u5FC5\u8981\u306A\u3059\u3079\u3066\u306E\u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u3067\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
