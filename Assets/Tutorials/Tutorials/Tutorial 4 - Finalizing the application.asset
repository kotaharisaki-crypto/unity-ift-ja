    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Hierarchy \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Moto</b>
      GameObject \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n2. <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067\u3001<b>Robot
      Variant</b> \u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u304C\u8FFD\u52A0\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u307E\u3059\u3002\n\n3.
      Robot Variant \u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u306E <b>Variants</b>
      \u30BB\u30AF\u30B7\u30E7\u30F3\u3092\u5C55\u958B\u3057\u307E\u3059\u3002\n\n4.
      <b>Add (+)</b> \u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u3066\u3001\u65B0\u3057\u3044\u30D0\u30EA\u30A2\u30F3\u30C8\u3092\u4F5C\u6210\u3057\u307E\u3059\u3002\n\n5.
      <b>Hierarchy</b> \u3067\u3001<b>Moto Gameobject</b> \u3092 <b>Moto</b> > <b>moto.SLDASM</b>
      > <b>moto</b> > <b>Default</b> > <b>level_02-1</b> > <b>level_03-1</b> \u307E\u3067\u5C55\u958B\u3057\u307E\u3059\u3002\n\n6.
      \u3053\u306E <b>level_03-1</b> GameObject \u3092 <b>Object to Enable</b> \u30B9\u30ED\u30C3\u30C8\u306B\u30C9\u30E9\u30C3\u30B0\u3057\u307E\u3059\u3002\n\n7.
      \u540C\u3058 <b>level_03-1</b> GameObject \u3092\u30B3\u30D4\u30FC\u3057\u3066\u3001<b>Part
      That Moves</b> \u30D5\u30A3\u30FC\u30EB\u30C9\u306B\u8CBC\u308A\u4ED8\u3051\u307E\u3059\u3002\n\n8.
      <b>Movement Axis</b> \u3092 <b>Z</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n9.
      <b>Starting Value</b> \u3092 <b>-3</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n10.
      <b>Ending Value</b> \u3092 <b>-2.5</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n11.
      \u4EE3\u308F\u308A\u306B <b>level_03_variant_01-1</b> GameObject \u3092\u4F7F\u7528\u3057\u3066\u3001\u624B\u9806
      4\uFF5E10 \u3092\u7E70\u308A\u8FD4\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
