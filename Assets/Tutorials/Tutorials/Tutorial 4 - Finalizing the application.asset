  m_Name: NarrativeParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "\u30ED\u30DC\u30C3\u30C8\u306F\u30DE\u30CB\u30E5\u30A2\u30EB\u30E2\u30FC\u30C9\u3068\u30AA\u30FC\u30C8\u30E2\u30FC\u30C9\u306E\u4E21\u65B9\u3092\u30B5\u30DD\u30FC\u30C8\u3057\u3066\u3044\u307E\u3059\u3002\u30DE\u30CB\u30E5\u30A2\u30EB\u30E2\u30FC\u30C9\u3067\u306F\u30AD\u30FC\u30DC\u30FC\u30C9\u3067\u30ED\u30DC\u30C3\u30C8\u3092\u64CD\u4F5C\u3067\u304D\u3001\u30AA\u30FC\u30C8\u30E2\u30FC\u30C9\u3067\u306F\u30ED\u30DC\u30C3\u30C8\u304C\u5009\u5EAB\u5185\u306E\u4E8B\u524D\u5B9A\u7FA9\u3055\u308C\u305F\u30A6\u30A7\u30A4\u30DD\u30A4\u30F3\u30C8\u9593\u3092\u81EA\u5F8B\u7684\u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u4E21\u65B9\u306E\u30E2\u30FC\u30C9\u3092\u30C6\u30B9\u30C8\u3057\u3001\u52D5\u4F5C\u304C\u30EA\u30A2\u30EB\u30BF\u30A4\u30E0\u3067\u5909\u5316\u3059\u308B\u69D8\u5B50\u3092\u89B3\u5BDF\u3057\u307E\u3059\u3002"
--- !u!114 &-5212420604749216343
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. \u518D\u5EA6 <b>Play</b> \u30E2\u30FC\u30C9\u3092\u30A2\u30AF\u30C6\u30A3\u30D6\u306B\u3057\u307E\u3059\u3002\n\n<b>\u6CE8:</b>
      \u30A2\u30D7\u30EA\u30B1\u30FC\u30B7\u30E7\u30F3\u30E1\u30CB\u30E5\u30FC\u3092\u898B\u3084\u3059\u304F\u3059\u308B\u305F\u3081\u306B\u3001Game
      \u30A6\u30A3\u30F3\u30C9\u30A6\u3092\u6700\u5927\u5316\u3059\u308B\u3053\u3068\u3092\u304A\u52E7\u3081\u3057\u307E\u3059\u3002\n\n2.
      <b>\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9</b>\u3067\u3001<b>\u30D0\u30EA\u30A2\u30F3\u30C8\u5207\u66FF
      (Variant Switcher)</b> \u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u307E\u3059\u3002\u30ED\u30DC\u30C3\u30C8\u306E\u30D3\u30B8\u30E5\u30A2\u30EB\u30E2\u30C7\u30EB\u304C\u6B21\u306E\u30D0\u30EA\u30A2\u30F3\u30C8\u306B\u66F4\u65B0\u3055\u308C\u307E\u3059\u3002\n\n3.
      <b>\u30A2\u30FC\u30E0\u7BC4\u56F2 (Arm Range)</b> \u30B9\u30E9\u30A4\u30C0\u30FC\u3092\u4F7F\u7528\u3057\u3066\u3001\u65B0\u3057\u3044\u30D0\u30EA\u30A2\u30F3\u30C8\u3067\u3082\u30A2\u30CB\u30E1\u30FC\u30B7\u30E7\u30F3\u304C\u52D5\u4F5C\u3059\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u307E\u3059\u3002\n\n4.
      <b>\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9</b>\u306E\u5DE6\u30D1\u30CD\u30EB\u3067\u3001\u65B0\u3057\u3044\u30ED\u30DC\u30C3\u30C8\u306E\u30AB\u30FC\u30C9\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5.
      <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067\u3001<b>Assets > Warehouse
      > RobotData</b> \u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n6. \u30ED\u30DC\u30C3\u30C8\u306B\u30EA\u30F3\u30AF\u3055\u308C\u3066\u3044\u308B
      <b>Robot Data</b> ScriptableObject \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n7.
      <b>Inspector</b> \u3067\u3001<b>Battery</b> \u3092 <b>50</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002UI
      \u306B <b>50%</b> \u3068\u8868\u793A\u3055\u308C\u3001<b>\u8B66\u544A (\u9EC4\u8272)</b>
      \u72B6\u614B\u306B\u306A\u308A\u307E\u3059\u3002\n\n8. <b>Battery</b> \u3092
      <b>20</b> \u306B\u5909\u66F4\u3057\u307E\u3059\u3002UI \u304C <b>20%</b> \u306B\u66F4\u65B0\u3055\u308C\u3001<b>\u91CD\u5927
      (\u8D64\u8272)</b> \u30B9\u30C6\u30FC\u30BF\u30B9\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\n\n9.
      <b>Inspector</b> \u3067\u3001<b>Health</b> \u3092 <b>0</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\u30ED\u30DC\u30C3\u30C8\u306F
      <b>DEAD</b> \u30B9\u30C6\u30FC\u30BF\u30B9\u306B\u306A\u308A\u3001\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9\u306E\u30AB\u30FC\u30C9\u306B<b>\u91CD\u5927\u306A\u30B9\u30BF\u30A4\u30EA\u30F3\u30B0</b>\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\u30ED\u30DC\u30C3\u30C8\u304C\u3053\u306E\u72B6\u614B\u306E\u9593\u3001\u79FB\u52D5\u30B3\u30DE\u30F3\u30C9\u306F\u7121\u8996\u3055\u308C\u307E\u3059\u3002"
