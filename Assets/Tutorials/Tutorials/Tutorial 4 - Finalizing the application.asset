  m_Name: NarrativeParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "1. <b>Unity \u30A8\u30C7\u30A3\u30BF\u30FC</b>\u306E\u4E0A\u90E8\u306B\u3042\u308B
      <b>Play</b> \u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002
      <b>\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9</b>\u306E\u5DE6\u30D1\u30CD\u30EB\u306B\u65B0\u3057\u3044\u30ED\u30DC\u30C3\u30C8\u30AB\u30FC\u30C9\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\u30AB\u30FC\u30C9\u306F\u30A2\u30EB\u30D5\u30A1\u30D9\u30C3\u30C8\u9806\u306B\u30BD\u30FC\u30C8\u3055\u308C\u3001\u5408\u8A08\u30ED\u30DC\u30C3\u30C8\u6570\u304C
      <b>1</b> \u5897\u3048\u307E\u3059\u3002\n\n2. <b>\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9</b>\u306E\u5DE6\u30D1\u30CD\u30EB\u3067\u3001\u65B0\u3057\u3044\u30ED\u30DC\u30C3\u30C8\u306E\u30AB\u30FC\u30C9\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u307E\u3059\u3002\u9078\u629E\u3055\u308C\u305F\u30AB\u30FC\u30C9\u304C\u30CF\u30A4\u30E9\u30A4\u30C8\u3055\u308C\u307E\u3059\u3002
      <b>\u53F3\u5074\u306E\u30D1\u30CD\u30EB</b>\u306B\u306F\u9078\u629E\u3055\u308C\u305F\u30ED\u30DC\u30C3\u30C8\u306E\u8A73\u7D30\u30C7\u30FC\u30BF\u304C\u8868\u793A\u3055\u308C\u3001
      <b>\u30AB\u30E1\u30E9</b>\u306F\u30B7\u30FC\u30F3\u5185\u306E\u30ED\u30DC\u30C3\u30C8\u3092\u8FFD\u3046\u3088\u3046\u306B\u30B9\u30E0\u30FC\u30BA\u306B\u5207\u308A\u66FF\u308F\u308A\u307E\u3059\u3002"
