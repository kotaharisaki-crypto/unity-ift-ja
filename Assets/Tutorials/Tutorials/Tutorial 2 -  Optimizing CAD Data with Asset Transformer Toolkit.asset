--- !u!114 &1713637103541854467
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 935228c0fd2628c4db5028980babef0b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "\u8907\u96D1\u306A\u30E2\u30C7\u30EB\u306E\u5834\u5408\u3001\u500B\u3005\u306E\u30D1\u30FC\u30C4\u3092\u6700\u9069\u5316\u3059\u308B\u306E\u306F\u6642\u9593\u304C\u304B\u304B\u308B\u3053\u3068\u304C\u3042\u308A\u307E\u3059\u3002\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u30A2\u30BB\u30F3\u30D6\u30EA\u5168\u4F53\u306B\u30C7\u30B7\u30E1\u30FC\u30B7\u30E7\u30F3\uFF08\u30DD\u30EA\u30B4\u30F3\u524A\u6E1B\uFF09\u3092\u9069\u7528\u3057\u307E\u3059\u3002\u3053\u308C\u306F\u3001\u30E2\u30D0\u30A4\u30EB\u3084
      Web \u7528\u306E\u30ED\u30FC\u30DD\u30EA\u30B4\u30F3\u30D0\u30FC\u30B8\u30E7\u30F3\u3092\u4F5C\u6210\u3059\u308B\u5834\u5408\u306B\u4FBF\u5229\u3067\u3059\u3002\n\n\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u306E\u76EE\u7684\u306F\u3001\u30E2\u30C7\u30EB\u306E\u9AD8\u5EA6\u306B\u7C21\u7D20\u5316\u3055\u308C\u305F\u3001\u975E\u5E38\u306B\u4F4E\u3044\u30DD\u30EA\u30B4\u30F3\u6570\u306E\u30D0\u30FC\u30B8\u30E7\u30F3\u3092\u751F\u6210\u3059\u308B\u3053\u3068\u3067\u3059\u3002\u3053\u306E\u6700\u9069\u5316\u3055\u308C\u305F\u30A2\u30BB\u30C3\u30C8\u306F\u3001Web
      \u307E\u305F\u306F\u30E2\u30D0\u30A4\u30EB\u74B0\u5883\u3067\u306E\u52B9\u7387\u7684\u306A\u30EA\u30A2\u30EB\u30BF\u30A4\u30E0\u30A2\u30D7\u30EA\u30B1\u30FC\u30B7\u30E7\u30F3\u7528\u306B\u7279\u5225\u306B\u8A2D\u8A08\u3055\u308C\u3066\u3044\u307E\u3059\u3002"
