    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "CAD\u30E2\u30C7\u30EB\u3092\u4F5C\u6210\u3059\u308B\u969B\u3001\u3059\u3079\u3066\u306E\u88FD\u9020\u304A\u3088\u3073\u7D44\u307F\u7ACB\u3066\u306E\u8A73\u7D30\u3092\u8A18\u9332\u3059\u308B\u3053\u3068\u304C\u91CD\u8981\u3067\u3059\u3002\u3053\u308C\u306B\u306F\u3001\u30D5\u30A1\u30B9\u30CA\u30FC\uFF08\u30CD\u30B8\u3001\u30DC\u30EB\u30C8\u306A\u3069\uFF09\u7528\u306E\u958B\u53E3\u90E8\u306E\u3088\u3046\u306A\u30E2\u30C7\u30EA\u30F3\u30B0\u6A5F\u80FD\u304C\u542B\u307E\u308C\u308B\u3053\u3068\u304C\u591A\u304F\u3001\u30E2\u30C7\u30EB\u306B\u30B8\u30AA\u30E1\u30C8\u30EA\u304C\u8FFD\u52A0\u3055\u308C\u307E\u3059\u3002\u3057\u304B\u3057\u3001\u3053\u308C\u3089\u306E\u8A73\u7D30\u306A\u958B\u53E3\u90E8\u306F\u3001\u30D1\u30FC\u30C4\u304C\u30E6\u30FC\u30B6\u30FC\u306B\u898B\u3048\u306A\u3044\u9818\u57DF\u3067\u5358\u7D14\u306B\u4EA4\u5DEE\u3067\u304D\u308B\u305F\u3081\u3001\u30EA\u30A2\u30EB\u30BF\u30A4\u30E0\u30E2\u30C7\u30EB\u3067\u306F\u4E0D\u8981\u306A\u5834\u5408\u304C\u591A\u3044\u3067\u3059\u3002"
