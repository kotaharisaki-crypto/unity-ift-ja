--- !u!114 &-1698418311231669840
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Hierarchy</b> \u3067 <b>glider_support_02-2</b> \u3068\u3044\u3046\u540D\u524D\u306E\u30D1\u30FC\u30C4\u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n2.
      <b>Scene \u30D3\u30E5\u30FC</b>\u3067\u30D1\u30FC\u30C4\u3092\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3001<b>Isolate</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3. <b>F</b> \u30AD\u30FC\u3092\u62BC\u3057\u3066\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306B\u30D5\u30A9\u30FC\u30AB\u30B9\u3057\u307E\u3059\u3002\n\n4.
      <b>ATT \u30C4\u30FC\u30EB\u30D0\u30FC</b>\u3067 <b>Remove Holes</b> \u30AA\u30D7\u30B7\u30E7\u30F3\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5.
      <b>Max Diameter</b> \u3092 <b>0.01</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n6.
      <b>Run</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\u7A74\u304C\u524A\u9664\u3055\u308C\u305F\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002\u3053\u308C\u306F\u3001\u30E2\u30C7\u30EB\u5185\u306E\u4E0D\u8981\u306A\u9802\u70B9\u304C\u6E1B\u308B\u305F\u3081\u3001\u30B8\u30AA\u30E1\u30C8\u30EA\u3092\u6700\u9069\u5316\u3059\u308B\u7C21\u5358\u306A\u65B9\u6CD5\u3067\u3059\u3002\n\n7.
      <b>glider_support_02-2</b> \u3068\u3044\u3046\u540D\u524D\u306E\u3082\u3046\u4E00\u65B9\u306E\u30D1\u30FC\u30C4\u306B\u3064\u3044\u3066\u3082\u3001\u540C\u3058\u624B\u9806\u3092\u7E70\u308A\u8FD4\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
--- !u!114 &-1604469990639674176
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. \u30B8\u30AA\u30E1\u30C8\u30EA\u5BC6\u5EA6\u3092\u8996\u899A\u5316\u3059\u308B\u306B\u306F\u3001<b>Scene
      \u30D3\u30E5\u30FC\u30C4\u30FC\u30EB\u30D0\u30FC</b> \u306E Debug \u30C9\u30ED\u30C3\u30D7\u30C0\u30A6\u30F3\u30E1\u30CB\u30E5\u30FC\u3092\u9078\u629E\u3057\u3001<b>Vertex
      Ratio</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n2. <b>Vertex Ratio</b>
      \u3092\u9078\u629E\u3057\u3066\u3001\u30E2\u30C7\u30EB\u5168\u4F53\u306E\u30E1\u30C3\u30B7\u30E5\u5BC6\u5EA6\u3092\u5F37\u8ABF\u8868\u793A\u3057\u307E\u3059\u3002\n\n3.
      <b>Scene \u30D3\u30E5\u30FC</b> \u3067\u8D64\u304F\u5F37\u8ABF\u8868\u793A\u3055\u308C\u305F\u30D1\u30FC\u30C4\u306E
      1 \u3064\u3092\u898B\u3064\u3051\u3066\u9078\u629E\u3057\u307E\u3059\u3002
      <b>Hierarchy</b> \u3067\u3001\u305D\u306E\u30D1\u30FC\u30C4\u306E\u307F\u304C\u9078\u629E\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002\n
      \n4. <b>ATT</b> \u30C4\u30FC\u30EB\u30D0\u30FC\u3067 <b>Decimate</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5.
      <b>Criterion</b> \u3092 <b>Target</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n6.
      <b>Strategy</b> \u3092 <b>Ratio</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n7.
      <b>Ratio</b> \u30B9\u30E9\u30A4\u30C0\u30FC\u3092 <b>30</b> \u306B\u8ABF\u6574\u3057\u307E\u3059\u3002\n\n8.
      <b>Run</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n9. \u30C7\u30B7\u30E1\u30FC\u30C8\u3057\u305F\u3044\u4ED6\u306E\u30D1\u30FC\u30C4\u306B\u3064\u3044\u3066\u3082\u3001\u3053\u308C\u3092\u7E70\u308A\u8FD4\u3057\u307E\u3059\u3002\n\n10.
      \u7D42\u4E86\u3057\u305F\u3089\u30C7\u30D0\u30C3\u30B0\u30E1\u30CB\u30E5\u30FC\u3092\u7121\u52B9\u306B\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
