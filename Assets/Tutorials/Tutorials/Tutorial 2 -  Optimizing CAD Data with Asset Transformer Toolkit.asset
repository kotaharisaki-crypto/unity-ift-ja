    m_Untranslated: "\u6CD5\u7DDA\u304C\u518D\u8A08\u7B97\u3055\u308C\u3001\u8868\u9762\u306E\u30A2\u30FC\u30C6\u30A3\u30D5\u30A1\u30AF\u30C8\u304C\u89E3\u6D88\u3055\u308C\u307E\u3057\u305F\u3002\n\n<b>\u5B8C\u4E86</b>
      \u3092\u9078\u629E\u3057\u3066\u6B21\u306E\u30C1\u30E5\u30FC\u30C8\u30EA\u30A2\u30EB\u306B\u9032\u307F\u307E\u3059\u3002\n\n<b>\u6CE8:</b>
