  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Assets</b> > <b>3DModels</b>\u3067\u3001\u65B0\u3057\u304F\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F<b>Moto
      \u30D7\u30EC\u30CF\u30D6</b>\u3092\u518D\u5EA6\u898B\u3064\u3051\u3066\u3001\u524D\u56DE\u3068\u540C\u3058\u3088\u3046\u306B<b>Hierarchy</b>\u306B\u30C9\u30E9\u30C3\u30B0\u3057\u307E\u3059\u3002\n\n2.
      <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067<b>Transform</b>\u3092\u518D\u5EA6\u30EA\u30BB\u30C3\u30C8\u3057\u3066\u3001\u30D7\u30EC\u30CF\u30D6\u3092\u30B7\u30FC\u30F3\u306E\u4E2D\u5FC3\u306B\u914D\u7F6E\u3057\u307E\u3059\u3002\n\n3.
      <b>Hierarchy</b>\u3067<b>Moto\u30D7\u30EC\u30CF\u30D6</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4. \u5404\u30D1\u30FC\u30C4\u304C\u3001\u7A7A\u306E\u89AA<b>GameObject</b>\u3068\u5B50\u306E\u30E1\u30C3\u30B7\u30E5<b>GameObject</b>\u3067\u69CB\u6210\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002\u89AA\u306B\u306F\u30E1\u30BF\u30C7\u30FC\u30BF\u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u304C\u542B\u307E\u308C\u3001\u30E1\u30C3\u30B7\u30E5\u304C\u5B9F\u969B\u306E\u30B8\u30AA\u30E1\u30C8\u30EA\u3067\u3059\u3002\u3053\u308C\u30892\u3064\u30921\u3064\u306E<b>GameObject</b>\u306B\u30DE\u30FC\u30B8\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
