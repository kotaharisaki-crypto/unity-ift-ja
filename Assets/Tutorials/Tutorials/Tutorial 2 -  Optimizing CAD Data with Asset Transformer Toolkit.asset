  m_Name: 
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Statistics \u30D1\u30CD\u30EB</b> \u3092\u3082\u3046\u4E00\u5EA6\u958B\u304D\u307E\u3059\u3002\u30ED\u30DC\u30C3\u30C8\u30E2\u30C7\u30EB\u306E\u4E09\u89D2\u5F62\u304C
      50 \u4E07\u500B\u3092\u8D85\u3048\u3066\u3044\u308B\u3053\u3068\u306B\u6CE8\u76EE\u3057\u3066\u304F\u3060\u3055\u3044\u3002
      CAD \u30E2\u30C7\u30EB\u306F\u901A\u5E38\u3001\u975E\u5E38\u306B\u9AD8\u5BC6\u5EA6\u306A\u30E2\u30C7\u30EB\u3067\u3042\u308A\u3001\u30EA\u30A2\u30EB\u30BF\u30A4\u30E0\u3067\u306E\u4F7F\u7528\u5411\u3051\u306B\u6700\u9069\u5316\u3055\u308C\u3066\u3044\u307E\u305B\u3093\u3002\n\n2.
      <b>Hierarchy</b> \u3067 <b>Moto</b> \u89AA GameObject (\u30C8\u30C3\u30D7\u30EC\u30D9\u30EB\u30E2\u30C7\u30EB)
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3. <b>Unity Asset Transform Toolkit</b>
      \u30C4\u30FC\u30EB\u30D0\u30FC\u304B\u3089 <b>Decimate</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      <b>Criterion</b> \u3092 <b>Quality</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n5.
      <b>Mesh Quality Preset</b> \u3092 <b>Low</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n6.
      <b>Run</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n7. <b>Statistics \u30D1\u30CD\u30EB</b>
      \u3092\u3082\u3046\u4E00\u5EA6\u898B\u3066\u304F\u3060\u3055\u3044\u3002\u4E09\u89D2\u5F62\u304C
      66% \u524A\u6E1B\u3055\u308C\u305F\u3053\u3068\u304C\u308F\u304B\u308A\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
