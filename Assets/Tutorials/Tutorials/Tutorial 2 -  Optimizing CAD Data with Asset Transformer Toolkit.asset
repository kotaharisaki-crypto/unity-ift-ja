    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Debug</b>\u30C9\u30ED\u30C3\u30D7\u30C0\u30A6\u30F3\u3067\u3001<b>Show
      Back-faces</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\u30D0\u30C3\u30AF\u30D5\u30A7\u30A4\u30B9\u304C\u8868\u9762\u304B\u3089\u900F\u3051\u3066\u898B\u3048\u308B\u305F\u3081\u3001\u7A74\u3092\u7C21\u5358\u306B\u898B\u3064\u3051\u3089\u308C\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002\n\n2.
      \u30ED\u30DC\u30C3\u30C8\u306E\u30B5\u30C3\u30AB\u30FC\u90E8\u5206\u3092\u78BA\u8A8D\u3057\u307E\u3059\u2014\u9752\u8272\u306E\u9818\u57DF\u306F\u30B8\u30AA\u30E1\u30C8\u30EA\u304C\u6B20\u843D\u3057\u3066\u3044\u308B\u3053\u3068\u3092\u793A\u3057\u307E\u3059\u3002\n\n3.
      <b>Hierarchy</b>\u3067\u3001\u30ED\u30DC\u30C3\u30C8\u306E\u3059\u3079\u3066\u306E\u30B5\u30C3\u30AB\u30FC\u3092Shift\u30AF\u30EA\u30C3\u30AF\u3067\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      <b>UATT</b>\u30C4\u30FC\u30EB\u30D0\u30FC\u304B\u3089\u3001<b>Remove Holes</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5.
      \u8A2D\u5B9A\u306F\u305D\u306E\u307E\u307E\u306B\u3057\u3066\u3001<b>Run</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
