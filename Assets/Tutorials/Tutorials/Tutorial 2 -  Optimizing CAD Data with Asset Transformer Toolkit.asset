  m_Name: 
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "CAD \u304B\u3089\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F\u30A2\u30BB\u30F3\u30D6\u30EA\u306B\u306F\u3001\u5197\u9577\u307E\u305F\u306F\u904E\u5EA6\u306B\u8907\u96D1\u306A\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u69CB\u9020\u304C\u542B\u307E\u308C\u308B\u3053\u3068\u304C\u3088\u304F\u3042\u308A\u307E\u3059\u3002\u3053\u308C\u3089\u306E\u69CB\u9020\u3092\u7C21\u7D20\u5316\u3059\u308B\u3068\u3001\u30D1\u30D5\u30A9\u30FC\u30DE\u30F3\u30B9\u304C\u5411\u4E0A\u3057\u3001\u30B7\u30FC\u30F3\u306E\u7BA1\u7406\u304C\u5BB9\u6613\u306B\u306A\u308A\u307E\u3059\u3002<br>\n\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001<b>Unity
      Asset Transformer Toolkit (ATT)</b> \u3092\u4F7F\u7528\u3057\u3066\u6700\u7D42\u30EC\u30D9\u30EB\u306E
      <b>GameObjects</b> \u3092\u30DE\u30FC\u30B8\u3057\u3001<b>Hierarchy</b> \u5185\u306E\u4E0D\u8981\u306A\u5165\u308C\u5B50\u3092\u6E1B\u3089\u3057\u307E\u3059\u3002"
