  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F\u30E2\u30C7\u30EB\u306E\u5909\u66F4\u3084\u30D5\u30A3\u30EB\u30BF\u30EA\u30F3\u30B0\u306B\u52A0\u3048\u3066\u3001\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u306F\u5B9F\u884C\u6642\u306B\u30D7\u30EC\u30CF\u30D6\u3092\u8FFD\u52A0\u307E\u305F\u306F\u7F6E\u63DB\u3059\u308B\u3053\u3068\u3082\u3067\u304D\u307E\u3059\u3002\u3053\u308C\u306F\u3001\u8907\u96D1\u306A\u30A2\u30BB\u30F3\u30D6\u30EA\u30C4\u30FC\u30EB\u306E\u69CB\u7BC9\u3084\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F\u30A2\u30BB\u30C3\u30C8\u3078\u306E\u8FFD\u52A0\u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u306E\u88DC\u5F37\u306B\u5F79\u7ACB\u3061\u307E\u3059\u3002\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001LightRig
      \u30D7\u30EC\u30CF\u30D6\u3092\u30ED\u30DC\u30C3\u30C8\u306B\u81EA\u52D5\u7684\u306B\u8FFD\u52A0\u3057\u3001\u6A5F\u80FD\u7684\u306A\u30ED\u30DC\u30C3\u30C8\u30E9\u30A4\u30C8\u3092\u30B7\u30DF\u30E5\u30EC\u30FC\u30C8\u3059\u308B\u3088\u3046\u306B\u914D\u7F6E\u3059\u308B\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u4F5C\u6210\u3057\u307E\u3059\u3002"
