--- !u!114 &555981092726408254
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>RuleSets</b> \u30D5\u30A9\u30EB\u30C0\u3067 <b>Replace
      Material</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u30C0\u30D6\u30EB\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u958B\u304D\u307E\u3059\u3002\n\n2.
      \u305D\u306E\u540D\u524D\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u3001<b>Copy</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3. <b>Assets > RuleSets</b> \u30D5\u30A9\u30EB\u30C0\u3067
      <b>Replace Materials on Metadata</b> \u30A2\u30BB\u30C3\u30C8\u3092\u30C0\u30D6\u30EB\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u958B\u304D\u307E\u3059\u3002\n\n4.
      <b>Replace Materials on Metadata</b> \u30A8\u30C7\u30A3\u30BF\u30FC\u3067\u3001\u30EB\u30FC\u30EB\u30EA\u30B9\u30C8\u306E\u6700\u5F8C\u307E\u3067\u30B9\u30AF\u30ED\u30FC\u30EB\u3057\u307E\u3059\u3002\n\n5.
      \u6700\u5F8C\u306E\u30EB\u30FC\u30EB\u3067 <b>3 \u70B9\u30C9\u30C3\u30C8 (\u22EE)
      \u30E1\u30CB\u30E5\u30FC</b>\u3092\u958B\u304D\u3001<b>Paste</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n<b>Replace
      Material</b> \u30EB\u30FC\u30EB\u304C <b>Replace Materials on Metadata</b>
      \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u306B\u8FFD\u52A0\u3055\u308C\u307E\u3057\u305F\u3002\u3053\u308C\u306B\u3088\u308A\u3001\u30BB\u30C3\u30C8\u30A2\u30C3\u30D7\u624B\u9806\u3092\u7E70\u308A\u8FD4\u3059\u3053\u3068\u306A\u304F\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u30D7\u30ED\u30BB\u30B9\u306B\u81EA\u52D5\u30DE\u30C6\u30EA\u30A2\u30EB\u7F6E\u63DB\u3092\u542B\u3081\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
--- !u!114 &699668839402648121
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets
      > Rule Sets</b> \u306B\u79FB\u52D5\u3057\u3001<b>Replace Material</b> \u30A2\u30BB\u30C3\u30C8\u3092\u30C0\u30D6\u30EB\u30AF\u30EA\u30C3\u30AF\u3057\u307E\u3059\u3002
      <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u306E\u6A2A\u306B\u65B0\u3057\u3044\u30BF\u30D6\u304C\u8868\u793A\u3055\u308C\u3001<b>Rule
      Sets Editor</b> \u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002 <b>Get</b>
      \u30A2\u30AF\u30B7\u30E7\u30F3\u304C\u3059\u3067\u306B\u5B58\u5728\u3057\u3066\u3044\u308B\u306E\u304C\u308F\u304B\u308A\u307E\u3059\u3002\u3053\u308C\u306F\u30EB\u30FC\u30EB\u304C\u9069\u7528\u3055\u308C\u308B\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u6C7A\u5B9A\u3057\u3001Hierarchy
      \u3067\u4F55\u304C\u9078\u629E\u3055\u308C\u3066\u3044\u308B\u304B\u306B\u3088\u3063\u3066\u5909\u5316\u3057\u307E\u3059\u3002\n\n2.
      <b>Assets > 3DModels</b> \u3067\u3001\u65B0\u3057\u304F\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F
      <b>Moto \u30D7\u30EC\u30CF\u30D6</b>\u3092\u518D\u5EA6\u898B\u3064\u3051\u3066\u3001<b>Hierarchy</b>
      \u306B\u30C9\u30E9\u30C3\u30B0\u3057\u307E\u3059\u3002\n\n3. <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067
      <b>Transform</b> \u3092\u3082\u3046\u4E00\u5EA6\u30EA\u30BB\u30C3\u30C8\u3057\u3001\u30D7\u30EC\u30CF\u30D6\u3092\u30B7\u30FC\u30F3\u306E\u4E2D\u5FC3\u306B\u914D\u7F6E\u3057\u307E\u3059\u3002\n\n4.
      <b>Hierarchy \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Moto \u30D7\u30EC\u30CF\u30D6</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002
      <b>Get</b> \u30A2\u30AF\u30B7\u30E7\u30F3\u304C\u66F4\u65B0\u3055\u308C\u3001\u30BD\u30FC\u30B9\u304C
      <b>Moto (GameObject)</b> \u3068\u3057\u3066\u8868\u793A\u3055\u308C\u307E\u3059\u3002\n\n5.
      <b>Rule Sets Editor</b> \u3067 <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6.
      <b>Filter > Filter on Metadata</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\u3053\u306E\u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u4F7F\u7528\u3059\u308B\u3068\u3001\u30E1\u30BF\u30C7\u30FC\u30BF\u5024\u306B\u57FA\u3065\u3044\u3066\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F
      CAD \u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u30D5\u30A3\u30EB\u30BF\u30EA\u30F3\u30B0\u3067\u304D\u307E\u3059\u3002\n\n7.
      <b>Property Filter</b> \u3067 <b>Filter String</b> \u306E\u5024\u3092 <b>MaterialName</b>
      \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n8. <b>Value Filter</b> \u3067
      <b>Filter String</b> \u306E\u5024\u3092 <b>Yellow_Metallic_powder_coat_01</b>
      \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n9. <b>Include Subhierarchy</b>
      \u30AA\u30D7\u30B7\u30E7\u30F3\u3092\u6709\u52B9\u306B\u3057\u307E\u3059\u3002\n\n10.
      \u518D\u5EA6 <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n11.
      <b>Set > Set Material</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n12.
      \u65B0\u3057\u3044\u30A2\u30AF\u30B7\u30E7\u30F3\u3067\u3001<b>Material</b>
      \u30D7\u30ED\u30D1\u30C6\u30A3\u30D5\u30A3\u30FC\u30EB\u30C9\u306E\u6A2A\u306B\u3042\u308B\u30E9\u30B8\u30AA\u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u3001<b>Yellow_Metallic_powder_coat_01</b>
      \u3092\u5272\u308A\u5F53\u3066\u307E\u3059\u3002\n\n13. Rule Set \u30BF\u30D6\u3067
      <b>Run</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\u30EB\u30FC\u30EB\u306F
      <b>Moto \u30D7\u30EC\u30CF\u30D6</b>\u306E\u5B50\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u691C\u7D22\u3057\u3001\u6307\u5B9A\u3055\u308C\u305F\u30E1\u30BF\u30C7\u30FC\u30BF\u306B\u4E00\u81F4\u3059\u308B\u3082\u306E\u3092\u898B\u3064\u3051\u3066\u3001<b>Yellow_Metallic_powder_coat</b>
      \u30DE\u30C6\u30EA\u30A2\u30EB\u3092\u5272\u308A\u5F53\u3066\u307E\u3059\u3002\n\n14.
      \u30EB\u30FC\u30EB\u540D\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\u540D\u524D\u3092 <b>Yellow_Metallic_powder_coat</b>
      \u306B\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
--- !u!114 &1404201277660737661
MonoBehaviour:
  m_ObjectHideFlags: 1
