  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets
      > RuleSets</b> \u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n2. \u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3066
      <b>Create > Asset Transformer > Rule Set</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3.
      \u65B0\u3057\u3044\u30A2\u30BB\u30C3\u30C8\u306B <b>Bake Ambient Occlusion</b>
      \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002\n\n4. <b>Add
      Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5. <b>Bake Ambient
      Occlusion</b> \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n6.
      <b>Storage Method</b> \u3092 <b>Vertex Color</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n7.
      <b>Samples</b> \u3092 16 \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n8. <b>Denoiser</b>
      \u3092 <b>Low</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n9. <b>Advanced
      \u30BB\u30AF\u30B7\u30E7\u30F3</b>\u3092\u5C55\u958B\u3057\u3001<b>Singularize
      Instances</b> \u30AA\u30D7\u30B7\u30E7\u30F3\u3092\u6709\u52B9\u306B\u3057\u307E\u3059\u3002\n\n10.
      \u30EB\u30FC\u30EB\u540D\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30C9\u30C3\u30C8
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u958B\u304D\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n11. \u30EB\u30FC\u30EB\u540D\u3092
      <b>Bake Main Model</b> \u306B\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
