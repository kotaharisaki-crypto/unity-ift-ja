  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets</b>
      \u30D5\u30A9\u30EB\u30C0\u3092\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3001<b>Create
      > Folder</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n2. \u30D5\u30A9\u30EB\u30C0\u306B
      <b>RuleSets</b> \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002\n3.
      <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets > RuleSets</b>
      \u306B\u79FB\u52D5\u3057\u3001\u30D5\u30A9\u30EB\u30C0\u3092\u958B\u304D\u307E\u3059\u3002\n4.
      RuleSets \u30D5\u30A9\u30EB\u30C0\u5185\u3092\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3001<b>Create
      > Asset Transformer > Rule Set</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n5.
      \u65B0\u3057\u3044\u30A2\u30BB\u30C3\u30C8\u306B <b>Replace Material</b> \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
