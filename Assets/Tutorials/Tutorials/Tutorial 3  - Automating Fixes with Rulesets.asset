  Text:
    m_Untranslated: "\u8907\u6570\u306E\u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u542B\u3080\u8907\u96D1\u306A\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u69CB\u7BC9\u3059\u308B\u5834\u5408\u306F\u3001\u305D\u308C\u3089\u3092\u5C0F\u3055\u304F\u540D\u524D\u4ED8\u304D\u306E\u30B5\u30D6\u30EB\u30FC\u30EB\u306B\u5206\u5272\u3059\u308B\u306E\u304C\u6700\u5584\u3067\u3059\u3002\u3053\u308C\u306B\u3088\u308A\u30ED\u30B8\u30C3\u30AF\u304C\u6574\u7406\u3055\u308C\u3001\u4E3B\u8981\u306A\u30B9\u30C6\u30C3\u30D7\u9593\u3067\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u9078\u629E\u304C\u78BA\u5B9F\u306B\u30EA\u30BB\u30C3\u30C8\u3055\u308C\u307E\u3059\u3002"
--- !u!114 &5929284874858877105
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 935228c0fd2628c4db5028980babef0b, type: 3}
  m_Name: NarrativeParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "CAD \u30E2\u30C7\u30EB\u306F\u3001\u30B9\u30E0\u30FC\u30BA\u306A\u30B7\u30A7\u30FC\u30C7\u30A3\u30F3\u30B0\u304C\u6B20\u3051\u3066\u3044\u305F\u308A\u3001\u4E0D\u6574\u5408\u306A\u6CD5\u7DDA\u30C7\u30FC\u30BF\u304C\u542B\u307E\u308C\u3066\u3044\u305F\u308A\u3059\u308B\u3053\u3068\u304C\u3088\u304F\u3042\u308A\u3001\u3053\u308C\u304C
      Unity \u3067\u306E\u7C97\u3044\u30A8\u30C3\u30B8\u3084\u4E0D\u6B63\u78BA\u306A\u30E9\u30A4\u30C6\u30A3\u30F3\u30B0\u306B\u3064\u306A\u304C\u308B\u53EF\u80FD\u6027\u304C\u3042\u308A\u307E\u3059\u3002\u3053\u308C\u3092\u4FEE\u6B63\u3059\u308B\u306B\u306F\u3001<b>Unity
      Asset Transformer Toolkit (ATT)</b> \u306E <b>Create Normals (Smoothness)</b>
      \u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u4F7F\u7528\u3067\u304D\u307E\u3059\u3002\u3053\u306E\u30C4\u30FC\u30EB\u306F\u30E2\u30C7\u30EB\u5168\u4F53\u306E\u6CD5\u7DDA\u3092\u518D\u8A08\u7B97\u3057\u3001\u3088\u308A\u30B9\u30E0\u30FC\u30BA\u306A\u8996\u899A\u7684\u7D50\u679C\u3092\u3082\u305F\u3089\u3057\u307E\u3059\u3002\n\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u4E2D\u306B\u30B9\u30E0\u30FC\u30BA\u306A\u6CD5\u7DDA\u3092\u81EA\u52D5\u7684\u306B\u751F\u6210\u3059\u308B\u305F\u3081\u306E\u5225\u306E\u30EB\u30FC\u30EB\u3092\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u306B\u8FFD\u52A0\u3057\u307E\u3059\u3002"
--- !u!114 &5988846519689910067
