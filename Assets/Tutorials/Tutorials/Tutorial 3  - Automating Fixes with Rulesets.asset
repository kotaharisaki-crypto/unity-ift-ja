  Text:
    m_Untranslated: "\u30A4\u30F3\u30DD\u30FC\u30C8\u4E2D\u306B\u30E2\u30C7\u30EB\u5168\u4F53\u306B\u9069\u7528\u3055\u308C\u308B\u57FA\u672C\u7684\u306A
      AO \u30D9\u30A4\u30AF\u30EB\u30FC\u30EB\u304C\u4F5C\u6210\u3055\u308C\u307E\u3057\u305F\u3002\u6B21\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u3053\u306E\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u62E1\u5F35\u3057\u3066\u3001\u30E2\u30C7\u30EB\u306E\u7279\u5B9A\u306E\u30D1\u30FC\u30C4\u3092\u30BF\u30FC\u30B2\u30C3\u30C8\u306B\u3057\u307E\u3059\u3002"
--- !u!114 &-3212019947421067349
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>RuleSets</b> \u30D5\u30A9\u30EB\u30C0\u3067 <b>Replace
      Material</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u30C0\u30D6\u30EB\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u958B\u304D\u307E\u3059\uFF08\u307E\u3060\u958B\u3044\u3066\u3044\u306A\u3044\u5834\u5408\uFF09\u3002\n\n2.
      \u30EB\u30FC\u30EB\u540D\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u3001<b>Copy</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3. <b>Assets > RuleSets</b> \u30D5\u30A9\u30EB\u30C0\u3067
      <b>Replace Materials on Metadata</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u30C0\u30D6\u30EB\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u958B\u304D\u307E\u3059\u3002\n\n4.
      <b>Replace Materials on Metadata</b> \u30A8\u30C7\u30A3\u30BF\u30FC\u3067\u3001\u30EB\u30FC\u30EB\u30EA\u30B9\u30C8\u306E\u6700\u5F8C\u307E\u3067\u30B9\u30AF\u30ED\u30FC\u30EB\u3057\u307E\u3059\u3002\n\n5.
      \u6700\u5F8C\u306E\u30EB\u30FC\u30EB\u306E\u4E0B\u306B\u3042\u308B <b>Add Rule</b>
      \u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6. \u3053\u306E\u65B0\u3057\u3044\u30EB\u30FC\u30EB\u306B\u3042\u308B
      <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u3001<b>Paste</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\u3053\u308C\u3067 <b>Yellow_Metallic_powder_coat</b>
      \u30EB\u30FC\u30EB\u304C\u3053\u306E\u65B0\u3057\u3044\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u306B\u8FFD\u52A0\u3055\u308C\u307E\u3057\u305F\u3002\n\n7.
      <b>Hierarchy</b> \u3067\u30C8\u30C3\u30D7\u30EC\u30D9\u30EB\u306E <b>Moto GameObject</b>
      \u304C\u9078\u629E\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3001<b>Replace
      Materials on Metadata</b> \u30A6\u30A3\u30F3\u30C9\u30A6\u3067\u30EB\u30FC\u30EB\u3092
      <b>Run</b> \u3057\u307E\u3059\u3002\u3059\u3079\u3066\u306E\u30DE\u30C6\u30EA\u30A2\u30EB\u304C\u30AB\u30B9\u30BF\u30E0\u4F5C\u6210\u3055\u308C\u305F
      Unity \u30B7\u30A7\u30FC\u30C0\u30FC\u306B\u7F6E\u304D\u63DB\u308F\u308A\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
