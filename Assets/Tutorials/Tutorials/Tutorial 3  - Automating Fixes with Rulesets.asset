  Text:
    m_Untranslated: "\u3053\u306E\u30EB\u30FC\u30EB\u306F\u30E2\u30C7\u30EB\u306E\u30D1\u30FC\u30C4\u306B\u81EA\u52D5\u7684\u306B\u30B3\u30E9\u30A4\u30C0\u30FC\u3092\u8FFD\u52A0\u3057\u3001\u30EC\u30A4\u30AD\u30E3\u30B9\u30C8\u3001\u885D\u7A81\u3001\u30C8\u30EA\u30AC\u30FC\u306A\u3069\u306E\u7269\u7406\u30A4\u30F3\u30BF\u30E9\u30AF\u30B7\u30E7\u30F3\u306E\u6E96\u5099\u3092\u6574\u3048\u307E\u3059\u3002"
--- !u!114 &-1214511991072225197
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Add Rule</b> \u3092\u9078\u629E\u3057\u3066\u65B0\u3057\u3044\u30B9\u30C6\u30C3\u30D7\u3092\u4F5C\u6210\u3057\u307E\u3059\u3002\n\n2.
      \u30EB\u30FC\u30EB\u5185\u3067 <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3.
      <b>Filter on Name</b> \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      <b>Filter String</b> \u3092 <b>level_03_variant_01-1</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n5.
      <b>Include Subhierarchy</b> \u3092\u6709\u52B9\u306B\u3057\u3066\u3001\u30D5\u30A3\u30EB\u30BF\u30EA\u30F3\u30B0\u3055\u308C\u305F\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u3059\u3079\u3066\u306E\u5B50\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6.
      \u518D\u5EA6 <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n7.
      <b>Bake Ambient Occlusion</b> \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n8.
      <b>Storage Method</b> \u3092 <b>Vertex Color</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n9.
      <b>Samples</b> \u3092 <b>16</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n10.
      <b>Denoiser</b> \u3092 <b>Low</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n11.
      <b>Advanced \u30BB\u30AF\u30B7\u30E7\u30F3</b>\u3092\u5C55\u958B\u3057\u3001<b>Singularize
      Instances</b> \u30AA\u30D7\u30B7\u30E7\u30F3\u3092\u6709\u52B9\u306B\u3057\u307E\u3059\u3002\n\n12.
      \u30EB\u30FC\u30EB\u540D\u3092 <b>Bake Variant 1</b> \u306B\u5909\u66F4\u3057\u307E\u3059\u3002\n\n<b>\u30EB\u30FC\u30EB\u3092\u8907\u88FD\u3057\u3066\u5225\u306E\u30D0\u30EA\u30A2\u30F3\u30C8\u7528\u306B\u8ABF\u6574\u3057\u307E\u3059\u3002</b>\n\n13.
      <b>Bake Variant 1</b> \u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30C9\u30C3\u30C8
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u958B\u304D\u3001<b>Duplicate</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n14. \u8907\u88FD\u3055\u308C\u305F\u30EB\u30FC\u30EB\u3067\u3001<b>Filter
      String</b> \u3092 <b>level_03-1</b> \u306B\u5909\u66F4\u3057\u307E\u3059\u3002\n\n15.
      \u30EB\u30FC\u30EB\u540D\u3092 <b>Bake Variant 2</b> \u306B\u5909\u66F4\u3057\u307E\u3059\u3002\n\n16.
      \u30EB\u30FC\u30EB\u3092 <b>Run</b> \u3057\u307E\u3059\u3002\u5B8C\u4E86\u307E\u3067\u306B\u6642\u9593\u304C\u304B\u304B\u308B\u5834\u5408\u304C\u3042\u308A\u307E\u3059\u3002\n\n17.
      \u9802\u70B9\u306B\u30D9\u30A4\u30AF\u3055\u308C\u305F <b>Ambient Occlusion</b>
      \u3092\u78BA\u8A8D\u3059\u308B\u306B\u306F\u3001<b>Debug \u30C9\u30ED\u30C3\u30D7\u30C0\u30A6\u30F3\u30E1\u30CB\u30E5\u30FC</b>\u306B\u79FB\u52D5\u3057\u3001<b>Vertex
      Colors</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
