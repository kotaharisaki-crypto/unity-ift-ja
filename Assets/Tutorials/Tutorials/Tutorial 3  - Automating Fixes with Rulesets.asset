    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u304C\u8907\u96D1\u306B\u306A\u308B\u306B\u3064\u308C\u3066\u3001\u305D\u308C\u3089\u3092\u5C0F\u3055\u304F\u518D\u5229\u7528\u53EF\u80FD\u306A\u90E8\u5206\u306B\u5206\u5272\u3059\u308B\u3068\u5F79\u7ACB\u3061\u307E\u3059\u3002<b>Run
      Rules</b> \u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u4F7F\u7528\u3059\u308B\u3068\u3001\u73FE\u5728\u306E\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u5185\u304B\u3089\u4ED6\u306E\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u30C8\u30EA\u30AC\u30FC\u3067\u304D\u307E\u3059\u3002\u3053\u308C\u306B\u3088\u308A\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u4E2D\u306B\u3059\u3079\u3066\u3092\u51E6\u7406\u3059\u308B\u30DE\u30B9\u30BF\u30FC\u30EB\u30FC\u30EB\u3092\u69CB\u7BC9\u3057\u306A\u304C\u3089\u3001\u30ED\u30B8\u30C3\u30AF\u3092\u7BA1\u7406\u3057\u3084\u3059\u3044\u30C1\u30E3\u30F3\u30AF\u306B\u6574\u7406\u3067\u304D\u307E\u3059\u3002\n\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u4EE5\u524D\u306B\u4F5C\u6210\u3057\u305F\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u65B0\u3057\u3044\u30DE\u30B9\u30BF\u30FC\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3067\u53C2\u7167\u3059\u308B\u3053\u3068\u3067\u3001\u305D\u308C\u3089\u3092\u30EA\u30F3\u30AF\u3057\u307E\u3059\u3002"
--- !u!114 &4573188419241988244
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Hierarchy</b> \u3067 <b>Moto GameObject</b> \u3092\u5C55\u958B\u3059\u308B\u3068\u3001<b>lightPlaceHolder-1</b>
      \u3068\u3044\u3046 GameObject \u304C\u3042\u308B\u3053\u3068\u306B\u6C17\u3065\u304F\u3067\u3057\u3087\u3046\u3002\u3053\u308C\u306F
      CAD \u6280\u8853\u8005\u304C Unity \u3067\u306E\u6700\u7D42\u7684\u306A\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u8868\u3059\u305F\u3081\u306B\u4F5C\u6210\u3057\u305F<b>\u30D7\u30EC\u30FC\u30B9\u30DB\u30EB\u30C0\u30FC
      GameObject</b> \u3067\u3059\u3002\u3053\u308C\u306B\u3088\u308A\u3001Unity
      \u958B\u767A\u8005\u3084\u30A2\u30FC\u30C6\u30A3\u30B9\u30C8\u306F CAD \u30C1\u30FC\u30E0\u3068\u52B9\u7387\u7684\u306B\u9023\u643A\u3067\u304D\u3001\u6A19\u6E96\u7684\u306A\u30A2\u30BB\u30C3\u30C8\u7D71\u5408\u30EF\u30FC\u30AF\u30D5\u30ED\u30FC\u306E\u81EA\u52D5\u5316\u306B\u5F79\u7ACB\u3061\u307E\u3059\u3002\n\n2.
      <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets > RuleSets</b>
      \u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n3. \u30D5\u30A9\u30EB\u30C0\u5185\u3092\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3001<b>Create
      > Asset Transformer > Rule Set</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      \u65B0\u3057\u3044\u30A2\u30BB\u30C3\u30C8\u306B <b>Add Lights</b> \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002\n\n5.
      \u30EB\u30FC\u30EB\u540D\u306E\u6A2A\u306B\u3042\u308B 3 \u70B9\u30C9\u30C3\u30C8\u30E1\u30CB\u30E5\u30FC\u3092\u958B\u304D\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6. \u30EB\u30FC\u30EB\u306B <b>Add
      Action</b> \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002\n\n7.
      <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n8. <b>Filter
      on Name</b> \u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n9.
      \u30D5\u30A3\u30EB\u30BF\u6587\u5B57\u5217\u3092 <b>lightPlaceHolder-1</b>
      \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n10. <b>Add Action</b> \u3092\u9078\u629E\u3057\u3001<b>Replace
      by</b> \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\u3053\u306E\u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u4F7F\u7528\u3059\u308B\u3068\u3001Unity
      \u3067\u6307\u5B9A\u3057\u305F\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3092\u5225\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306B\u7F6E\u304D\u63DB\u3048\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002\n\n11.
      <b>Replace by</b> \u30A2\u30AF\u30B7\u30E7\u30F3\u3067\u3001<b>GameObject</b>
      \u30D5\u30A3\u30FC\u30EB\u30C9\u306E\u6A2A\u306B\u3042\u308B<b>\u30E9\u30B8\u30AA\u30DC\u30BF\u30F3</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n12.
      \u30BB\u30EC\u30AF\u30BF\u30FC\u30A6\u30A3\u30F3\u30C9\u30A6\u3067 Assets \u3092\u9078\u629E\u3057\u3001<b>LightRig_CAD</b>
      \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u3001\u8FFD\u52A0\u3059\u308B\u5B50\u30D7\u30EC\u30CF\u30D6\u3068\u3057\u3066\u5272\u308A\u5F53\u3066\u307E\u3059\u3002\n\n13.
      \u518D\u5EA6 <b>Add Action</b> \u3092\u9078\u629E\u3057\u3001<b>Set Transform</b>
      \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n14. <b>Referential
      \u304C Self \u306B\u8A2D\u5B9A\u3055\u308C\u3066\u3044\u308B\u3053\u3068</b>\u3092\u78BA\u8A8D\u3057\u307E\u3059\u3002\n\n15.
      <b>Rotation</b> \u30D5\u30A3\u30FC\u30EB\u30C9\u3067 <b>Y \u5024</b>\u3092
      <b>-180</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n16. \u30EB\u30FC\u30EB\u3092
      <b>Run</b> \u3057\u307E\u3059\u3002\n\n17. \u518D\u5EA6 <b>Hierarchy</b> \u3067
      <b>Moto GameObject</b> \u3092\u5C55\u958B\u3059\u308B\u3068\u3001<b>lightPlaceHolder-1</b>
      \u304C\u3042\u3063\u305F\u5834\u6240\u306B <b>LightRig_CAD</b> \u304C\u8868\u793A\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u304C\u308F\u304B\u308A\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
