    m_Untranslated: "\u3053\u308C\u3067\u69CB\u6210\u306E\u6E96\u5099\u304C\u6574\u3063\u305F\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u30A2\u30BB\u30C3\u30C8\u304C\u4F5C\u6210\u3055\u308C\u307E\u3057\u305F\u3002\u6B21\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u30D7\u30ED\u30BB\u30B9\u4E2D\u306B\u3053\u306E\u30EB\u30FC\u30EB\u304C\u4F55\u3092\u884C\u3046\u304B\u3092\u5B9A\u7FA9\u3057\u307E\u3059\u3002"
--- !u!114 &-5135270759237683932
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Import Rules</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3067
      <b>Add Rule</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n2. \u524D\u306E\u30EB\u30FC\u30EB\u306E\u4E0B\u306B\u65B0\u3057\u3044\u30EB\u30FC\u30EB\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\n\n3.
      \u65B0\u3057\u3044\u30EB\u30FC\u30EB\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u958B\u304D\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4. \u30EB\u30FC\u30EB\u540D\u3092
      <b>Remove Holes</b> \u306B\u3057\u307E\u3059\u3002\n\n5. <b>Remove Holes</b>
      \u30EB\u30FC\u30EB\u3092\u9078\u629E\u3057\u305F\u72B6\u614B\u3067 <b>Add Action</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6. <b>Filter on Metadata</b>
      \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\u3053\u308C\u306B\u3088\u308A\u3001\u30E2\u30C7\u30EB\u306E\u7279\u5B9A\u306E\u30D1\u30FC\u30C4\u3092\u5206\u96E2\u3067\u304D\u307E\u3059\u3002\n\n7.
      <b>Property Filter</b> \u30BB\u30AF\u30B7\u30E7\u30F3\u3067 <b>Filter String</b>
      \u3092 <b>SW-File Name(File Name)</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n8.
      <b>Value Filter</b> \u30BB\u30AF\u30B7\u30E7\u30F3\u3067 <b>Filter String</b>
      \u3092 <b>glider_support_assm</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n9.
      <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n10. \u30A2\u30AF\u30B7\u30E7\u30F3\u30EA\u30B9\u30C8\u304B\u3089
      <b>Remove Holes</b> \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n11.
      Unity \u306F\u30C7\u30D5\u30A9\u30EB\u30C8\u3067\u30E1\u30FC\u30C8\u30EB\u3092\u4F7F\u7528\u3057\u307E\u3059\u3002\u5C0F\u3055\u306A\u958B\u53E3\u90E8\u306E\u307F\u304C\u524A\u9664\u3055\u308C\u308B\u3088\u3046\u306B\u3001<b>Max
      Diameter</b> \u3092 0.01 \u306B\u5909\u66F4\u3057\u307E\u3059\u3002\u3053\u308C\u306B\u3088\u308A\u300110mm
      \u672A\u6E80\u306E\u958B\u53E3\u90E8\u306E\u307F\u304C\u524A\u9664\u3055\u308C\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
