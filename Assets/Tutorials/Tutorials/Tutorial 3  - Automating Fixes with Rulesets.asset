  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "\u4E00\u90E8\u306E CAD \u30E2\u30C7\u30EB\u306B\u306F\u3001Unity
      \u3067\u30C6\u30AF\u30B9\u30C1\u30E3\u3084\u30E9\u30A4\u30C6\u30A3\u30F3\u30B0\u3092\u6B63\u3057\u304F\u9069\u7528\u3059\u308B\u305F\u3081\u306B\u4E0D\u53EF\u6B20\u306A
      UV \u30DE\u30C3\u30D4\u30F3\u30B0\u304C\u542B\u307E\u308C\u3066\u3044\u307E\u305B\u3093\u3002<b>Unity
      Asset Transformer Toolkit (UATT)</b> \u306E <b>Create UVs</b> \u30A2\u30AF\u30B7\u30E7\u30F3\u306F\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u4E2D\u306B
      UV \u5EA7\u6A19\u3092\u81EA\u52D5\u7684\u306B\u751F\u6210\u3057\u3001\u9069\u5207\u306A\u30DE\u30C6\u30EA\u30A2\u30EB\u30EC\u30F3\u30C0\u30EA\u30F3\u30B0\u3068\u30E9\u30A4\u30C8\u30DE\u30C3\u30D4\u30F3\u30B0\u306E\u6E96\u5099\u3092\u6574\u3048\u307E\u3059\u3002\n\u3053\u306E\u30B9\u30C6\u30C3\u30D7\u3067\u306F\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F\u30E2\u30C7\u30EB\u306E
      UV \u3092\u751F\u6210\u3059\u308B\u305F\u3081\u306E\u65B0\u3057\u3044\u30EB\u30FC\u30EB\u3092\u8FFD\u52A0\u3057\u307E\u3059\u3002"
--- !u!114 &-4264417300288363221
MonoBehaviour:
  m_ObjectHideFlags: 1
