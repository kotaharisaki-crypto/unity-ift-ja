--- !u!114 &1919695986211397410
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Import Rules</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3067
      <b>Add Rule</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n2. \u30EA\u30B9\u30C8\u306E\u6700\u5F8C\u306B\u65B0\u3057\u3044\u30EB\u30FC\u30EB\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002\n\n3.
      \u65B0\u3057\u3044\u30EB\u30FC\u30EB\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u958B\u304D\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4. \u30EB\u30FC\u30EB\u540D\u3092
      <b>Create Colliders</b> \u306B\u3057\u307E\u3059\u3002\n\n5. <b>Create Colliders</b>
      \u3092\u9078\u629E\u3057\u305F\u72B6\u614B\u3067 <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6.
      \u30A2\u30AF\u30B7\u30E7\u30F3\u30EA\u30B9\u30C8\u304B\u3089 <b>Create Collider</b>
      \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\n\n7. Strategy
      \u3092 <b>Retopology</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n8. <b>Mesh
      Quality</b> \u30D7\u30EA\u30BB\u30C3\u30C8\u3092 <b>Low</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
--- !u!114 &1978816384736208793
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Project \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Assets
      > 3DModels</b> \u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n2. <b>Moto</b>
      \u30A4\u30F3\u30DD\u30FC\u30C8\u30A2\u30BB\u30C3\u30C8\u3092\u9078\u629E\u3057\u307E\u3059\uFF08\u30D7\u30EC\u30CF\u30D6\u3084\u30B7\u30FC\u30F3\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3067\u306F\u3042\u308A\u307E\u305B\u3093\uFF09\u3002\n\n3.
      <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Rule Engine</b> \u30BF\u30D6\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      <b>Rule Set</b> \u3067\u30E9\u30B8\u30AA\u30DC\u30BF\u30F3\u3092\u9078\u629E\u3057\u3001\u5229\u7528\u53EF\u80FD\u306A\u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u306E\u30EA\u30B9\u30C8\u304B\u3089
      <b>Import Rule</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5. <b>Inspector
      \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067 <b>Model</b> \u30BF\u30D6\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6.
      <b>Mesh Quality</b> \u3092 <b>Medium</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\u3053\u306E\u8A2D\u5B9A\u306B\u3088\u308A\u3001\u30A4\u30F3\u30DD\u30FC\u30C8\u4E2D\u306B\u30E1\u30C3\u30B7\u30E5\u306E\u81EA\u52D5\u30C7\u30B7\u30E1\u30FC\u30B7\u30E7\u30F3\u304C\u6709\u52B9\u306B\u306A\u308B\u305F\u3081\u3001\u30EB\u30FC\u30EB\u306B\u500B\u5225\u306E\u30C7\u30B7\u30E1\u30FC\u30B7\u30E7\u30F3\u30B9\u30C6\u30C3\u30D7\u3092\u542B\u3081\u308B\u5FC5\u8981\u304C\u306A\u304F\u306A\u308A\u307E\u3059\u3002\n\n\n<b>\u30E2\u30C7\u30EB\u306E\u518D\u30A4\u30F3\u30DD\u30FC\u30C8</b>\n\n7.
      <b>Inspector</b> \u306E\u4E0B\u90E8\u306B\u3042\u308B <b>Re-Import</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n8.
      Unity \u306F CAD \u30A2\u30BB\u30C3\u30C8\u3092\u518D\u30A4\u30F3\u30DD\u30FC\u30C8\u3057\u3001<b>Import
      Rule</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3067\u5B9A\u7FA9\u3055\u308C\u305F\u3059\u3079\u3066\u306E\u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u81EA\u52D5\u7684\u306B\u9069\u7528\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
