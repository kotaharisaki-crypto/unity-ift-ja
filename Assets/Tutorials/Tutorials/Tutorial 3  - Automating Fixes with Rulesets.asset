  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>RuleSets</b> \u30D5\u30A9\u30EB\u30C0\u3067\u53F3\u30AF\u30EA\u30C3\u30AF\u3057\u3001<b>Create
      > Asset Transformer > Rule Set</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n2.
      \u65B0\u3057\u3044\u30A2\u30BB\u30C3\u30C8\u306B <b>Import Rules</b> \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002\n\n3.
      \u30EB\u30FC\u30EB\u540D\u306E\u6A2A\u306B\u3042\u308B 3 \u70B9\u30C9\u30C3\u30C8\u30E1\u30CB\u30E5\u30FC\u3092\u958B\u304D\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4. \u30EB\u30FC\u30EB\u540D\u3092
      <b>Rule 1</b> \u306B\u3057\u307E\u3059\u3002\n\n5. Rule Set Editor \u3067 <b>Add
      Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6. <b>Hierarchy >
      Merge</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n7. \u65B0\u3057\u3044\u30A2\u30AF\u30B7\u30E7\u30F3\u3067\u3001<b>Type</b>
      \u30D7\u30ED\u30D1\u30C6\u30A3\u3092 <b>Merge Final Level</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
