--- !u!114 &8101934002887551376
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. Rule Set Editor \u3067\u3001\u30EA\u30B9\u30C8\u306E\u6700\u521D\u306B\u3042\u308B\u30EB\u30FC\u30EB\u3092\u898B\u3064\u3051\u307E\u3059\u3002\n\n2.
      \u30EB\u30FC\u30EB\u540D\u306E\u6A2A\u306B\u3042\u308B <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC
      (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n3. \u65B0\u3057\u3044\u540D\u524D\u3068\u3057\u3066
      <b>Simplify Hierarchy</b> \u3092\u5165\u529B\u3057\u307E\u3059\u3002\n\n4.
      \u6700\u521D\u306E\u30EB\u30FC\u30EB\u306E\u4E0B\u306B\u3042\u308B <b>Add Rule</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5. \u65B0\u3057\u304F\u4F5C\u6210\u3055\u308C\u305F\u30EB\u30FC\u30EB\u3067
      <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u958B\u304D\u3001<b>Rename</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6. \u3053\u306E\u30EB\u30FC\u30EB\u306B
      <b>Fix Z Fighting</b> \u3068\u3044\u3046\u540D\u524D\u3092\u4ED8\u3051\u307E\u3059\u3002\n\n7.
      <b>Fix Z Fighting</b> \u30EB\u30FC\u30EB\u3092\u9078\u629E\u3057\u305F\u72B6\u614B\u3067
      <b>Add Action</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n8. \u30A2\u30AF\u30B7\u30E7\u30F3\u30EA\u30B9\u30C8\u304B\u3089
      <b>Remove Z-Fighting</b> \u3092\u691C\u7D22\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
