  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Import Rules</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3067
      <b>Add Rule</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n2. \u30A2\u30AF\u30B7\u30E7\u30F3\u30BF\u30A4\u30D7\u3092
      <b>Run Rules</b> \u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n3. <b>Run Rules</b>
      \u30A2\u30AF\u30B7\u30E7\u30F3\u3067 <b>Replace Materials on MetaData</b> \u30EB\u30FC\u30EB\u30BB\u30C3\u30C8\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      <b>\u30D7\u30E9\u30B9 (+) \u8A18\u53F7</b>\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u5225\u306E\u30EB\u30FC\u30EB\u3092\u8FFD\u52A0\u3057\u307E\u3059\u3002\n\n5.
      \u30E9\u30B8\u30AA\u30DC\u30BF\u30F3\u3092\u4F7F\u7528\u3057\u3066\u3001\u5B9F\u884C\u3059\u308B\u30EB\u30FC\u30EB\u3068\u3057\u3066
      <b>Bake Ambient Occlusion</b> \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n6.
      \u3082\u3046\u4E00\u5EA6<b>\u30D7\u30E9\u30B9 (+) \u8A18\u53F7</b>\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u307E\u3059\u3002\n\n7.
      \u30E9\u30B8\u30AA\u30DC\u30BF\u30F3\u3092\u4F7F\u7528\u3057\u3066 <b>Add Lights</b>
      \u30EB\u30FC\u30EB\u3092\u9078\u629E\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
