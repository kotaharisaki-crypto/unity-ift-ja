  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Window</b> > <b>Package Management</b> > <b>Package Manager</b>
      \u304B\u3089 Package Manager \u3092\u958B\u304D\u307E\u3059\u3002\n\n<b>\u6CE8:</b>
      <b>Asset Transformer Toolkit</b> \u306B\u306F Unity Industry \u30E9\u30A4\u30BB\u30F3\u30B9\u304C\u5FC5\u8981\u3067\u3059\u3002\u30E9\u30A4\u30BB\u30F3\u30B9\u304C\u306A\u3044\u5834\u5408\u3001\u30D1\u30C3\u30B1\u30FC\u30B8\u306F\u8868\u793A\u3055\u308C\u307E\u305B\u3093\u3002\n\n2.
      \u5DE6\u4E0A\u306E\u30C9\u30ED\u30C3\u30D7\u30C0\u30A6\u30F3\u3067\u3001<b>Packages
      location</b> \u3092 <b>Unity Registry</b> \u306B\u5207\u308A\u66FF\u3048\u307E\u3059\u3002\n\n3.
      <b>Asset Transformer Toolkit</b> \u3092\u691C\u7D22\u3057\u307E\u3059\u3002\n\n4.
      \u30D1\u30C3\u30B1\u30FC\u30B8\u3092\u9078\u629E\u3057\u3001<b>Install</b>
      \u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n5. Unity \u304C\u30D1\u30C3\u30B1\u30FC\u30B8\u3068\u305D\u306E\u4F9D\u5B58\u95A2\u4FC2\u306E\u30A4\u30F3\u30B9\u30C8\u30FC\u30EB\u3092\u5B8C\u4E86\u3059\u308B\u307E\u3067\u5F85\u3061\u307E\u3059\u3002\n\n6.
      <b>Package Manager</b> \u30A6\u30A3\u30F3\u30C9\u30A6\u3092\u9589\u3058\u307E\u3059\u3002\n\n7.
      Unity \u30A8\u30C7\u30A3\u30BF\u30FC\u306B\u65B0\u3057\u3044 <b>Asset Transformer</b>
      \u30E1\u30CB\u30E5\u30FC\u307E\u305F\u306F\u30C4\u30FC\u30EB\u30D0\u30FC\u304C\u8868\u793A\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u307E\u3059\u3002\n\n<b>\u6CE8</b>:
      \u30C4\u30FC\u30EB\u30D0\u30FC\u304C\u8868\u793A\u3055\u308C\u306A\u3044\u5834\u5408\u306F\u3001<b>Scene
      \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u306E\u53F3\u4E0A\u306B\u3042\u308B <b>3
      \u70B9\u30EA\u30FC\u30C0\u30FC (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u3001<b>Overlays
      > Overlay \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\u3053\u306E\u30E1\u30CB\u30E5\u30FC\u3067\u3001<b>Custom</b>
      > <b>Asset Transformer Toolbox</b> \u306E\u4E0B\u306E\u3059\u3079\u3066\u306E\u9805\u76EE\u304C\u6709\u52B9\u306B\u306A\u3063\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
  m_CriteriaCompletion: 1
  m_Criteria:
    m_Items:
