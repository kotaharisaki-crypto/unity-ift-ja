  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Project\u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067\u3001<b>Assets</b>
      > <b>3DModels</b>\u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n2. \u524D\u306E\u624B\u9806\u3067\u4F5C\u6210\u3055\u308C\u305F<b>Import
      ScriptableObject</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n<b>\u30E2\u30C7\u30EB\u8A2D\u5B9A\u306E\u69CB\u6210</b>\n\n3. <b>Inspector \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u3067\u3001
      <b>Model</b>\u30BF\u30D6\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4. <b>Scale</b>\u304C<b>0.001</b>\u306B\u8A2D\u5B9A\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002Unity\u306F\u30C7\u30D5\u30A9\u30EB\u30C8\u3067\u30E1\u30FC\u30C8\u30EB\u3092\u4F7F\u7528\u3059\u308B\u305F\u3081\u3001\u3053\u306E\u8A2D\u5B9A\u306B\u3088\u308ACAD\u30E2\u30C7\u30EB\u306E\u5358\u4F4D\uFF08\u3053\u306E\u5834\u5408\u306F\u30DF\u30EA\u30E1\u30FC\u30C8\u30EB\uFF09\u3092Unity\u306E\u30E1\u30FC\u30C8\u30EB\u306B\u5909\u63DB\u3067\u304D\u307E\u3059\u3002\n\n5.
      <b>Orientation</b>\u304C<b>Automatic</b>\u306B\u8A2D\u5B9A\u3055\u308C\u3066\u3044\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002\u3053\u308C\u306B\u3088\u308A\u3001\u30E2\u30C7\u30EB\u306FUnity\u306E\u30C7\u30D5\u30A9\u30EB\u30C8\u3067\u3042\u308B<b>Y-up</b>\u30B7\u30B9\u30C6\u30E0\u3092\u4F7F\u7528\u3059\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002\n\n6.
      <b>Import Metadata</b>\u304C\u6709\u52B9\u3067\u3042\u308B\u3053\u3068\u3092\u78BA\u8A8D\u3057\u3066\u304F\u3060\u3055\u3044\u3002\u30E1\u30BF\u30C7\u30FC\u30BF\u3092\u4F7F\u7528\u3059\u308B\u3068\u3001\u30E2\u30C7\u30EB\u306B\u95A2\u9023\u4ED8\u3051\u3089\u308C\u305F\u3059\u3079\u3066\u306E\u8CB4\u91CD\u306ACAD\u60C5\u5831\u3092\u5229\u7528\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002\n\n7.
      <b>Mesh Quality</b>\u3092<b>Maximum</b>\u306B\u8A2D\u5B9A\u3057\u307E\u3059\u3002\n\n8.
      <b>Repair Instances</b>\u306B\u30C1\u30A7\u30C3\u30AF\u3092\u5165\u308C\u3066\u3001\u7E70\u308A\u8FD4\u3057\u306E\u30B8\u30AA\u30E1\u30C8\u30EA\u3092\u6700\u9069\u5316\u3057\u307E\u3059\u3002\n\n9.
      Inspector\u3067<b>Re-Import</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
