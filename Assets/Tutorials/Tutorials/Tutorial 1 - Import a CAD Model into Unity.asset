      \u30A6\u30A3\u30F3\u30C9\u30A6</b>\u306B <b>Prefab</b> \u3068\u3057\u3066\u8868\u793A\u3055\u308C\u307E\u3059\u3002\u3053\u308C\u3092\u30B7\u30FC\u30F3\u306B\u914D\u7F6E\u3057\u3066\u3001\u305D\u306E\u69CB\u9020\u3068\u30E1\u30BF\u30C7\u30FC\u30BF\u3092\u78BA\u8A8D\u3067\u304D\u307E\u3059\u3002\n<b>\u30D2\u30F3\u30C8:</b>
