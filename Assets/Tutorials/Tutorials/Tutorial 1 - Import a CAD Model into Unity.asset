  m_Name: NarrativeParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.NarrativeParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Text:
    m_Untranslated: "<b>\u6CE8</b>: \u30A4\u30F3\u30DD\u30FC\u30C8\u5F8C\u3001\u30DC\u30BF\u30F3\u306F
      <b>Re-Import</b> \u306B\u5909\u308F\u308A\u307E\u3059\u3002\n\nImport \u3092\u9078\u629E\u3059\u308B\u3068\u3001Unity
      \u306F\u30D7\u30ED\u30B8\u30A7\u30AF\u30C8\u5185\u306B\u65B0\u3057\u3044\u30A4\u30F3\u30DD\u30FC\u30C8
      <b>ScriptableObject</b> \u3092\u4F5C\u6210\u3057\u307E\u3059\u3002\u3053\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306F\u30A4\u30F3\u30DD\u30FC\u30C8\u8A2D\u5B9A\u3092\u4FDD\u5B58\u3057\u3001\u4E00\u8CAB\u3057\u305F\u518D\u30A4\u30F3\u30DD\u30FC\u30C8\u3092\u53EF\u80FD\u306B\u3057\u307E\u3059\u3002\n\u30A4\u30F3\u30DD\u30FC\u30C8\u30D7\u30ED\u30BB\u30B9\u304C\u521D\u671F\u5316\u3055\u308C\u3001<b>ScriptableObject</b>
      \u306E\u69CB\u6210\u6E96\u5099\u304C\u6574\u3044\u307E\u3057\u305F\u3002"
--- !u!114 &-1469841882045615844
MonoBehaviour:
  m_ObjectHideFlags: 1
