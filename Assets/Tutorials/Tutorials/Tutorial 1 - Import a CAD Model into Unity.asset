--- !u!114 &-8999108370967053234
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 456c7c2b477e4253b9e4faf9ed4b18a9, type: 3}
  m_Name: InstructionsParagraph
  m_EditorClassIdentifier: Unity.Tutorials.Editor::Unity.Tutorials.Editor.Paragraphs.InstructionsParagraph
  m_MaskingSettings:
    m_MaskingEnabled: 0
    m_UnmaskedViews: []
    MaskPreset: {fileID: 0}
  Title:
    m_Untranslated: "\u624B\u9806"
  Text:
    m_Untranslated: "1. <b>Assets</b> > <b>3DModels</b>\u3067\u3001\u65B0\u3057\u304F\u30A4\u30F3\u30DD\u30FC\u30C8\u3055\u308C\u305F<b>Moto
      Prefab</b>\uFF08\u9752\u3044\u30AD\u30E5\u30FC\u30D6\u306E\u30A2\u30A4\u30B3\u30F3\u306E\u3082\u306E\uFF09\u3092\u898B\u3064\u3051\u307E\u3059\u3002\n\n2.
      Prefab\u3092<b>Hierarchy\u30A6\u30A3\u30F3\u30C9\u30A6</b>\u306B\u30C9\u30E9\u30C3\u30B0\u3057\u3066\u3001\u30B7\u30FC\u30F3\u306B\u8FFD\u52A0\u3057\u307E\u3059\u3002\n\n3.
      Inspector \u306E Transform \u30B3\u30F3\u30DD\u30FC\u30CD\u30F3\u30C8\u306E\u53F3\u5074\u306B\u3042\u308B
      <b>3 \u70B9\u30EA\u30FC\u30C0\u30FC (\u22EE) \u30E1\u30CB\u30E5\u30FC</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\n\n4.
      <b>Reset</b>\u3092\u9078\u629E\u3057\u307E\u3059\u3002\u3053\u308C\u306B\u3088\u308A\u3001\u30E2\u30C7\u30EB\u304C\u30EF\u30FC\u30EB\u30C9\u306E\u4E2D\u5FC3\u306B\u79FB\u52D5\u3057\u307E\u3059\u3002\n\n<b>\u30A4\u30F3\u30DD\u30FC\u30C8\u6E08\u307F\u30E1\u30BF\u30C7\u30FC\u30BF\u306E\u78BA\u8A8D</b>\n\n5. <b>Hierarchy</b> \u3067\u30D7\u30EC\u30CF\u30D6\u3092\u9078\u629E\u3057\u3066\u5C55\u958B\u3057\u307E\u3059\n\n6.
      \u3053\u306E\u30E2\u30C7\u30EB\u3092\u69CB\u6210\u3059\u308B\u5B50\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E1\u3064\u3092\u9078\u629E\u3057\u3066\u3001<b>Inspector</b>\u3092\u78BA\u8A8D\u3057\u307E\u3059\u3002\n\n7.
      \u30E2\u30C7\u30EB\u306B\u30A2\u30BF\u30C3\u30C1\u3055\u308C\u305F <b>names</b>\u3001<b>IDs</b>\u3001<b>properties</b>
      \u306A\u3069\u306E\u30E1\u30BF\u30C7\u30FC\u30BF\u30D5\u30A3\u30FC\u30EB\u30C9\u304C\u8868\u793A\u3055\u308C\u307E\u3059\u3002"
  m_CriteriaCompletion: 0
  m_Criteria:
    m_Items: []
